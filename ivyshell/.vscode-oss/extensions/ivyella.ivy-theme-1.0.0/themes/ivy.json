{
	"name": "IvyShell",
	"type": "dark",
	"colors": {
		"focusBorder": "#b4befe",
		"foreground": "#cdd6f4",
		"descriptionForeground": "#585b70",
		"errorForeground": "#f38ba8",
		"textLink.foreground": "#89b4fa",
		"textLink.activeForeground": "#b4befe",
		"textBlockQuote.background": "#11111b",
		"textBlockQuote.border": "#313244",
		"textCodeBlock.background": "#181825",
		"textPreformat.foreground": "#cdd6f4",
		"textSeparator.foreground": "#585b70",
		"button.background": "#a6e3a1",
		"button.foreground": "#11111b",
		"checkbox.background": "#1e1e2e",
		"checkbox.border": "#11111b",
		"dropdown.background": "#181825",
		"dropdown.border": "#11111b",
		"input.background": "#181825",
		"input.border": "#313244",
		"input.foreground": "#cdd6f4",
		"badge.background": "#89b4fa",
		"progressBar.background": "#b4befe",
		"titleBar.activeBackground": "#11111b",
		"titleBar.activeForeground": "#cdd6f4",
		"activityBar.background": "#11111b",
		"activityBar.foreground": "#b4befe",
		"activityBar.inactiveForeground": "#585b70",
		"sideBar.background": "#11111b",
		"sideBar.foreground": "#bac2de",
		"sideBar.border": "#11111b",
		"editor.background": "#181825",
		"editor.foreground": "#cdd6f4",
		"editor.lineHighlightBackground": "#1e1e2e",
		"editorCursor.foreground": "#b4befe",
		"editorIndentGuide.background": "#1e1e2e",
		"editorIndentGuide.activeBackground": "#313244",
		"editor.selectionBackground": "#b4befe44",
		"statusBar.background": "#11111b",
		"statusBar.foreground": "#bac2de",
		"statusBar.border": "#11111b",
		"editorGroupHeader.tabsBackground": "#11111b",
		"tab.activeBackground": "#181825",
		"tab.activeForeground": "#cdd6f4",
		"tab.inactiveBackground": "#11111b",
		"tab.inactiveForeground": "#585b70",
		"tab.border": "#11111b",
		"tab.activeBorderTop": "#b4befe",
		"list.hoverBackground": "#1e1e2e",
		"list.activeSelectionBackground": "#1e1e2e",
		"list.activeSelectionForeground": "#cdd6f4"
	},
	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment",
				"string.comment"
			],
			"settings": { "foreground": "#585b70" }
		},
		{
			"scope": [
				"constant",
				"entity.name.constant",
				"variable.other.constant",
				"variable.other.enummember",
				"variable.language"
			],
			"settings": { "foreground": "#89b4fa" }
		},
		{
			"scope": ["entity", "entity.name"],
			"settings": { "foreground": "#f5c2e7" }
		},
		{
			"scope": "variable.parameter.function",
			"settings": { "foreground": "#cdd6f4" }
		},
		{
			"scope": "entity.name.tag",
			"settings": { "foreground": "#a6e3a1" }
		},
		{
			"scope": "keyword",
			"settings": { "foreground": "#f38ba8" }
		},
		{
			"scope": ["storage", "storage.type"],
			"settings": { "foreground": "#f38ba8" }
		},
		{
			"scope": [
				"storage.modifier.package",
				"storage.modifier.import",
				"storage.type.java"
			],
			"settings": { "foreground": "#cdd6f4" }
		},
		{
			"scope": [
				"string",
				"punctuation.definition.string",
				"string punctuation.section.embedded source"
			],
			"settings": { "foreground": "#94e2d5" }
		},
		{
			"scope": ["support", "meta.property-name"],
			"settings": { "foreground": "#89b4fa" }
		},
		{
			"scope": "variable",
			"settings": { "foreground": "#f9e2af" }
		},
		{
			"scope": "variable.other",
			"settings": { "foreground": "#cdd6f4" }
		},
		{
			"scope": [
				"invalid.broken",
				"invalid.deprecated",
				"invalid.illegal",
				"invalid.unimplemented"
			],
			"settings": { "fontStyle": "italic", "foreground": "#f38ba8" }
		},
		{
			"scope": "string variable",
			"settings": { "foreground": "#89b4fa" }
		},
		{
			"scope": ["source.regexp", "string.regexp"],
			"settings": { "foreground": "#94e2d5" }
		},
		{
			"scope": "markup.heading",
			"settings": { "fontStyle": "bold", "foreground": "#89b4fa" }
		},
		{
			"scope": "markup.quote",
			"settings": { "foreground": "#a6e3a1" }
		},
		{
			"scope": "markup.italic",
			"settings": { "fontStyle": "italic", "foreground": "#cdd6f4" }
		},
		{
			"scope": "markup.bold",
			"settings": { "fontStyle": "bold", "foreground": "#cdd6f4" }
		},
		{
			"scope": "markup.inline.raw",
			"settings": { "foreground": "#89b4fa" }
		}
	],
	"semanticHighlighting": true
}
