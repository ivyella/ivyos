{
	"name": "IvyShell",
	"type": "dark",
	"colors": {
		"focusBorder": "#7e9cd8",
		"foreground": "#c5c9c5",
		"descriptionForeground": "#504945",
		"errorForeground": "#c4746e",
		"textLink.foreground": "#7e9cd8",
		"textLink.activeForeground": "#7e9cd8",
		"textBlockQuote.background": "#0d0c0c",
		"textBlockQuote.border": "#282727",
		"textCodeBlock.background": "#181616",
		"textPreformat.foreground": "#c5c9c5",
		"textSeparator.foreground": "#504945",
		"button.background": "#8a9a7b",
		"button.foreground": "#0d0c0c",
		"checkbox.background": "#1d1c19",
		"checkbox.border": "#0d0c0c",
		"dropdown.background": "#181616",
		"dropdown.border": "#0d0c0c",
		"input.background": "#181616",
		"input.border": "#282727",
		"input.foreground": "#c5c9c5",
		"badge.background": "#7e9cd8",
		"progressBar.background": "#7e9cd8",
		"titleBar.activeBackground": "#0d0c0c",
		"titleBar.activeForeground": "#c5c9c5",
		"activityBar.background": "#0d0c0c",
		"activityBar.foreground": "#7e9cd8",
		"activityBar.inactiveForeground": "#504945",
		"sideBar.background": "#0d0c0c",
		"sideBar.foreground": "#a6a69c",
		"sideBar.border": "#0d0c0c",
		"editor.background": "#181616",
		"editor.foreground": "#c5c9c5",
		"editor.lineHighlightBackground": "#1d1c19",
		"editorCursor.foreground": "#7e9cd8",
		"editorIndentGuide.background": "#1d1c19",
		"editorIndentGuide.activeBackground": "#282727",
		"editor.selectionBackground": "#7e9cd844",
		"statusBar.background": "#0d0c0c",
		"statusBar.foreground": "#a6a69c",
		"statusBar.border": "#0d0c0c",
		"editorGroupHeader.tabsBackground": "#0d0c0c",
		"tab.activeBackground": "#181616",
		"tab.activeForeground": "#c5c9c5",
		"tab.inactiveBackground": "#0d0c0c",
		"tab.inactiveForeground": "#504945",
		"tab.border": "#0d0c0c",
		"tab.activeBorderTop": "#7e9cd8",
		"list.hoverBackground": "#1d1c19",
		"list.activeSelectionBackground": "#1d1c19",
		"list.activeSelectionForeground": "#c5c9c5"
	},
	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment",
				"string.comment"
			],
			"settings": { "foreground": "#504945" }
		},
		{
			"scope": [
				"constant",
				"entity.name.constant",
				"variable.other.constant",
				"variable.other.enummember",
				"variable.language"
			],
			"settings": { "foreground": "#7e9cd8" }
		},
		{
			"scope": ["entity", "entity.name"],
			"settings": { "foreground": "#b98d7b" }
		},
		{
			"scope": "variable.parameter.function",
			"settings": { "foreground": "#c5c9c5" }
		},
		{
			"scope": "entity.name.tag",
			"settings": { "foreground": "#8a9a7b" }
		},
		{
			"scope": "keyword",
			"settings": { "foreground": "#c4746e" }
		},
		{
			"scope": ["storage", "storage.type"],
			"settings": { "foreground": "#c4746e" }
		},
		{
			"scope": [
				"storage.modifier.package",
				"storage.modifier.import",
				"storage.type.java"
			],
			"settings": { "foreground": "#c5c9c5" }
		},
		{
			"scope": [
				"string",
				"punctuation.definition.string",
				"string punctuation.section.embedded source"
			],
			"settings": { "foreground": "#8ea4a2" }
		},
		{
			"scope": ["support", "meta.property-name"],
			"settings": { "foreground": "#7e9cd8" }
		},
		{
			"scope": "variable",
			"settings": { "foreground": "#c4b28a" }
		},
		{
			"scope": "variable.other",
			"settings": { "foreground": "#c5c9c5" }
		},
		{
			"scope": [
				"invalid.broken",
				"invalid.deprecated",
				"invalid.illegal",
				"invalid.unimplemented"
			],
			"settings": { "fontStyle": "italic", "foreground": "#c4746e" }
		},
		{
			"scope": "string variable",
			"settings": { "foreground": "#7e9cd8" }
		},
		{
			"scope": ["source.regexp", "string.regexp"],
			"settings": { "foreground": "#8ea4a2" }
		},
		{
			"scope": "markup.heading",
			"settings": { "fontStyle": "bold", "foreground": "#7e9cd8" }
		},
		{
			"scope": "markup.quote",
			"settings": { "foreground": "#8a9a7b" }
		},
		{
			"scope": "markup.italic",
			"settings": { "fontStyle": "italic", "foreground": "#c5c9c5" }
		},
		{
			"scope": "markup.bold",
			"settings": { "fontStyle": "bold", "foreground": "#c5c9c5" }
		},
		{
			"scope": "markup.inline.raw",
			"settings": { "foreground": "#7e9cd8" }
		}
	],
	"semanticHighlighting": true
}
