{
	"name": "IvyShell",
	"type": "dark",
	"colors": {
		"focusBorder": "#39bae6",
		"foreground": "#bfbdb6",
		"descriptionForeground": "#3d4751",
		"errorForeground": "#f26d78",
		"textLink.foreground": "#59c2ff",
		"textLink.activeForeground": "#39bae6",
		"textBlockQuote.background": "#0b0e14",
		"textBlockQuote.border": "#1c2129",
		"textCodeBlock.background": "#0f1419",
		"textPreformat.foreground": "#bfbdb6",
		"textSeparator.foreground": "#3d4751",
		"button.background": "#aad94c",
		"button.foreground": "#0b0e14",
		"checkbox.background": "#131721",
		"checkbox.border": "#0b0e14",
		"dropdown.background": "#0f1419",
		"dropdown.border": "#0b0e14",
		"input.background": "#0f1419",
		"input.border": "#1c2129",
		"input.foreground": "#bfbdb6",
		"badge.background": "#59c2ff",
		"progressBar.background": "#39bae6",
		"titleBar.activeBackground": "#0b0e14",
		"titleBar.activeForeground": "#bfbdb6",
		"activityBar.background": "#0b0e14",
		"activityBar.foreground": "#39bae6",
		"activityBar.inactiveForeground": "#3d4751",
		"sideBar.background": "#0b0e14",
		"sideBar.foreground": "#8a9199",
		"sideBar.border": "#0b0e14",
		"editor.background": "#0f1419",
		"editor.foreground": "#bfbdb6",
		"editor.lineHighlightBackground": "#131721",
		"editorCursor.foreground": "#39bae6",
		"editorIndentGuide.background": "#131721",
		"editorIndentGuide.activeBackground": "#1c2129",
		"editor.selectionBackground": "#39bae644",
		"statusBar.background": "#0b0e14",
		"statusBar.foreground": "#8a9199",
		"statusBar.border": "#0b0e14",
		"editorGroupHeader.tabsBackground": "#0b0e14",
		"tab.activeBackground": "#0f1419",
		"tab.activeForeground": "#bfbdb6",
		"tab.inactiveBackground": "#0b0e14",
		"tab.inactiveForeground": "#3d4751",
		"tab.border": "#0b0e14",
		"tab.activeBorderTop": "#39bae6",
		"list.hoverBackground": "#131721",
		"list.activeSelectionBackground": "#131721",
		"list.activeSelectionForeground": "#bfbdb6"
	},
	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment",
				"string.comment"
			],
			"settings": { "foreground": "#3d4751" }
		},
		{
			"scope": [
				"constant",
				"entity.name.constant",
				"variable.other.constant",
				"variable.other.enummember",
				"variable.language"
			],
			"settings": { "foreground": "#59c2ff" }
		},
		{
			"scope": ["entity", "entity.name"],
			"settings": { "foreground": "#d2a6ff" }
		},
		{
			"scope": "variable.parameter.function",
			"settings": { "foreground": "#bfbdb6" }
		},
		{
			"scope": "entity.name.tag",
			"settings": { "foreground": "#aad94c" }
		},
		{
			"scope": "keyword",
			"settings": { "foreground": "#f26d78" }
		},
		{
			"scope": ["storage", "storage.type"],
			"settings": { "foreground": "#f26d78" }
		},
		{
			"scope": [
				"storage.modifier.package",
				"storage.modifier.import",
				"storage.type.java"
			],
			"settings": { "foreground": "#bfbdb6" }
		},
		{
			"scope": [
				"string",
				"punctuation.definition.string",
				"string punctuation.section.embedded source"
			],
			"settings": { "foreground": "#95e6cb" }
		},
		{
			"scope": ["support", "meta.property-name"],
			"settings": { "foreground": "#59c2ff" }
		},
		{
			"scope": "variable",
			"settings": { "foreground": "#e6b450" }
		},
		{
			"scope": "variable.other",
			"settings": { "foreground": "#bfbdb6" }
		},
		{
			"scope": [
				"invalid.broken",
				"invalid.deprecated",
				"invalid.illegal",
				"invalid.unimplemented"
			],
			"settings": { "fontStyle": "italic", "foreground": "#f26d78" }
		},
		{
			"scope": "string variable",
			"settings": { "foreground": "#59c2ff" }
		},
		{
			"scope": ["source.regexp", "string.regexp"],
			"settings": { "foreground": "#95e6cb" }
		},
		{
			"scope": "markup.heading",
			"settings": { "fontStyle": "bold", "foreground": "#59c2ff" }
		},
		{
			"scope": "markup.quote",
			"settings": { "foreground": "#aad94c" }
		},
		{
			"scope": "markup.italic",
			"settings": { "fontStyle": "italic", "foreground": "#bfbdb6" }
		},
		{
			"scope": "markup.bold",
			"settings": { "fontStyle": "bold", "foreground": "#bfbdb6" }
		},
		{
			"scope": "markup.inline.raw",
			"settings": { "foreground": "#59c2ff" }
		}
	],
	"semanticHighlighting": true
}
