layout {
    focus-ring {
        active-color "#252b35"
        inactive-color "#1c2129"
        urgent-color "#f26d78"
    }
    border {
        active-color "#252b35"
        inactive-color "#1c2129"
        urgent-color "#f26d78"
    }
    shadow {
        color "#00000070"
    }
    tab-indicator {
        active-color "#252b35"
        inactive-color "#1c2129"
        urgent-color "#f26d78"
    }
    insert-hint {
        color "#252b3580"
    }
}
