layout {
    focus-ring {
        active-color "#c8c8c8"
        inactive-color "#d9d9d9"
        urgent-color "#f07171"
    }
    border {
        active-color "#c8c8c8"
        inactive-color "#d9d9d9"
        urgent-color "#f07171"
    }
    shadow {
        color "#00000040"
    }
    tab-indicator {
        active-color "#c8c8c8"
        inactive-color "#d9d9d9"
        urgent-color "#f07171"
    }
    insert-hint {
        color "#c8c8c880"
    }
}
