layout {
    focus-ring {
        active-color "#737994"
        inactive-color "#626880"
        urgent-color "#e78284"
    }
    border {
        active-color "#737994"
        inactive-color "#626880"
        urgent-color "#e78284"
    }
    shadow {
        color "#00000070"
    }
    tab-indicator {
        active-color "#737994"
        inactive-color "#626880"
        urgent-color "#e78284"
    }
    insert-hint {
        color "#73799480"
    }
}
