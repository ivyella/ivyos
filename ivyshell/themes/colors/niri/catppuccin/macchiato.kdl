layout {
    focus-ring {
        active-color "#6e738d"
        inactive-color "#5b6078"
        urgent-color "#ed8796"
    }
    border {
        active-color "#6e738d"
        inactive-color "#5b6078"
        urgent-color "#ed8796"
    }
    shadow {
        color "#00000070"
    }
    tab-indicator {
        active-color "#6e738d"
        inactive-color "#5b6078"
        urgent-color "#ed8796"
    }
    insert-hint {
        color "#6e738d80"
    }
}
