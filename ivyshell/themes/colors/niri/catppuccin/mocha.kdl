layout {
    focus-ring {
        active-color "#6c7086"
        inactive-color "#585b70"
        urgent-color "#f38ba8"
    }
    border {
        active-color "#6c7086"
        inactive-color "#585b70"
        urgent-color "#f38ba8"
    }
    shadow {
        color "#00000070"
    }
    tab-indicator {
        active-color "#6c7086"
        inactive-color "#585b70"
        urgent-color "#f38ba8"
    }
    insert-hint {
        color "#6c708680"
    }
}
