layout {
    focus-ring {
        active-color "#495156"
        inactive-color "#414b50"
        urgent-color "#e67e80"
    }
    border {
        active-color "#495156"
        inactive-color "#414b50"
        urgent-color "#e67e80"
    }
    shadow {
        color "#00000070"
    }
    tab-indicator {
        active-color "#495156"
        inactive-color "#414b50"
        urgent-color "#e67e80"
    }
    insert-hint {
        color "#49515680"
    }
}
