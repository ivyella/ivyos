layout {
    focus-ring {
        active-color "#444c56"
        inactive-color "#373e47"
        urgent-color "#e5534b"
    }
    border {
        active-color "#444c56"
        inactive-color "#373e47"
        urgent-color "#e5534b"
    }
    shadow {
        color "#00000070"
    }
    tab-indicator {
        active-color "#444c56"
        inactive-color "#373e47"
        urgent-color "#e5534b"
    }
    insert-hint {
        color "#444c5680"
    }
}
