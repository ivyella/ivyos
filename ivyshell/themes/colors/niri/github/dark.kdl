layout {
    focus-ring {
        active-color "#30363d"
        inactive-color "#21262d"
        urgent-color "#da3633"
    }
    border {
        active-color "#30363d"
        inactive-color "#21262d"
        urgent-color "#da3633"
    }
    shadow {
        color "#00000070"
    }
    tab-indicator {
        active-color "#30363d"
        inactive-color "#21262d"
        urgent-color "#da3633"
    }
    insert-hint {
        color "#30363d80"
    }
}
