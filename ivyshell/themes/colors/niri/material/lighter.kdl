layout {
    focus-ring {
        active-color "#bdbdbd"
        inactive-color "#e0e0e0"
        urgent-color "#e53935"
    }
    border {
        active-color "#bdbdbd"
        inactive-color "#e0e0e0"
        urgent-color "#e53935"
    }
    shadow {
        color "#00000040"
    }
    tab-indicator {
        active-color "#bdbdbd"
        inactive-color "#e0e0e0"
        urgent-color "#e53935"
    }
    insert-hint {
        color "#bdbdbd80"
    }
}
