layout {
    focus-ring {
        active-color "#3c3f5c"
        inactive-color "#32354a"
        urgent-color "#f07178"
    }
    border {
        active-color "#3c3f5c"
        inactive-color "#32354a"
        urgent-color "#f07178"
    }
    shadow {
        color "#00000070"
    }
    tab-indicator {
        active-color "#3c3f5c"
        inactive-color "#32354a"
        urgent-color "#f07178"
    }
    insert-hint {
        color "#3c3f5c80"
    }
}
