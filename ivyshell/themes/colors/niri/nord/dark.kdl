layout {
    focus-ring {
        active-color "#4c566a"
        inactive-color "#3b4252"
        urgent-color "#bf616a"
    }
    border {
        active-color "#4c566a"
        inactive-color "#3b4252"
        urgent-color "#bf616a"
    }
    shadow {
        color "#00000070"
    }
    tab-indicator {
        active-color "#4c566a"
        inactive-color "#3b4252"
        urgent-color "#bf616a"
    }
    insert-hint {
        color "#4c566a80"
    }
}
