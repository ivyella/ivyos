layout {
    focus-ring {
        active-color "#44415a"
        inactive-color "#393552"
        urgent-color "#eb6f92"
    }
    border {
        active-color "#44415a"
        inactive-color "#393552"
        urgent-color "#eb6f92"
    }
    shadow {
        color "#00000070"
    }
    tab-indicator {
        active-color "#44415a"
        inactive-color "#393552"
        urgent-color "#eb6f92"
    }
    insert-hint {
        color "#44415a80"
    }
}
