layout {
    focus-ring {
        active-color "#444a73"
        inactive-color "#3b4261"
        urgent-color "#ff757f"
    }
    border {
        active-color "#444a73"
        inactive-color "#3b4261"
        urgent-color "#ff757f"
    }
    shadow {
        color "#00000070"
    }
    tab-indicator {
        active-color "#444a73"
        inactive-color "#3b4261"
        urgent-color "#ff757f"
    }
    insert-hint {
        color "#444a7380"
    }
}
